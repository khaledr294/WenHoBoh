rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Pharmacies Collection
    match /pharmacies/{pharmacyId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == pharmacyId;
    }

    // Customers Collection
    match /customers/{customerId} {
      allow read: if request.auth != null && request.auth.uid == customerId;
      allow write: if request.auth != null && request.auth.uid == customerId;
    }

    // CustomerRequests Collection
    match /customerRequests/{requestId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // PharmacyResponses Collection
    match /pharmacyResponses/{responseId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == resource.data.pharmacyId;
      allow delete: if false;
    }

    // Reservations Collection
    match /reservations/{reservationId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // SystemEvents Collection
    match /systemEvents/{eventId} {
      allow read: if true;
      allow create: if true; // Open temporarily for logging
      allow update, delete: if false;
    }
  }
}
